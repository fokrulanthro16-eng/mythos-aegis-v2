# ─────────────────────────────────────────────────────────────────────────────
# Mythos Aegis — Environment Configuration
# Copy this file to .env and fill in real values before running the service.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Application environment: development | staging | production
APP_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver).
# For Docker Compose the host is the service name "postgres".
# For local dev without Docker use "localhost".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mythos_aegis

# Set to true when connecting to a TLS-only host (Supabase, RDS, Cloud SQL).
# asyncpg receives ssl="require" in connect_args when this is true.
DB_SSL_REQUIRE=false

# Set to true when the target database has pgvector installed and the
# embedding column has been migrated to vector(768) via migration a1b2c3d4e5f6.
# When false the embedding column stays as ARRAY(Float) and similarity search
# falls back to numpy cosine similarity in Python.
USE_PGVECTOR=false

# ── Supabase (alternative to local PostgreSQL) ────────────────────────────────
# Replace DATABASE_URL above with this format when using Supabase.
# Use the "Direct connection" string from Settings → Database (port 5432).
# Also set DB_SSL_REQUIRE=true and USE_PGVECTOR=true.
#
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres
# DB_SSL_REQUIRE=true
# USE_PGVECTOR=true

# ── JWT Authentication ────────────────────────────────────────────────────────
# PRODUCTION: JWT_SECRET must be ≥32 characters and must not be the default.
#             Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=mythos-aegis-dev-secret-change-in-production
JWT_PREVIOUS_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=mythos-aegis
JWT_AUDIENCE=mythos-aegis-api
JWT_EXPIRY_SECONDS=3600

# ── Intent Parser ─────────────────────────────────────────────────────────────
# Minimum confidence score (0.0–1.0) before any action is dispatched.
# Inputs below this threshold are routed to CLARIFICATION.
INTENT_CONFIDENCE_THRESHOLD=0.85

# ── SQL Airlock ───────────────────────────────────────────────────────────────
# Maximum wall-clock seconds a SQL query may run before being cancelled.
SQL_TIMEOUT_SECONDS=3

# Hard upper bound on the number of rows returned by analytics queries.
SQL_MAX_LIMIT=100

# ── Redis (rate limiting) ─────────────────────────────────────────────────────
# For Docker Compose the host is the service name "redis".
# For local dev without Docker use "localhost".
# The app degrades gracefully (fail-open) if Redis is unavailable.
REDIS_URL=redis://localhost:6379/0

# ── OpenTelemetry Tracing ─────────────────────────────────────────────────────
# Set OTEL_ENABLED=true and point the endpoint at your collector in staging/prod.
# No collector is required for local development.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=mythos-aegis

# ── PostgreSQL (docker-compose only) ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mythos_aegis

# ── Ollama (local AI inference) ───────────────────────────────────────────────
# Ollama must be running locally: https://ollama.com
# Pull models: ollama pull qwen2.5:1.5b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=120.0

# ── AI Gateway (quota) ────────────────────────────────────────────────────────
AI_QUOTA_ENABLED=true
AI_MONTHLY_REQUEST_LIMIT=30000

# ── RAG Pipeline ─────────────────────────────────────────────────────────────
# Embedding model must be pulled in Ollama: ollama pull nomic-embed-text
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_DIMENSION=768
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_MAX_FILE_SIZE_MB=10
RAG_TOP_K=5

# ── Vision Intelligence ───────────────────────────────────────────────────────
# Vision model must be pulled: ollama pull qwen2.5-vl:7b
# Accepts JPEG, PNG, WebP, GIF. Max 20 MB.
VISION_MODEL=qwen2.5-vl:7b
VISION_FALLBACK_MODEL=llama3.2-vision:11b
VISION_MAX_IMAGE_SIZE_MB=20
VISION_ANALYSIS_TIMEOUT=120.0

# ── Agent Runtime ─────────────────────────────────────────────────────────────
AGENT_MODEL=qwen2.5:1.5b
AGENT_MAX_ITERATIONS=5
AGENT_MAX_CONTEXT_CHARS=8000

# ── Workflow Engine ───────────────────────────────────────────────────────────
WORKFLOW_MAX_STEPS=20
WORKFLOW_STEP_TIMEOUT=300.0
WORKFLOW_MAX_RETRY_ATTEMPTS=5

# ── Billing ───────────────────────────────────────────────────────────────────
# Set BILLING_PROVIDER=stripe for real Stripe integration.
# Leave as "mock" for local demo — all billing actions are simulated.
BILLING_PROVIDER=mock
# Only required when BILLING_PROVIDER=stripe:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
